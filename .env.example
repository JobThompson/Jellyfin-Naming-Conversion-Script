# Required: folder containing your media files.
# Can be a library root or a single show folder.
# Movie files placed directly in this root are auto-detected as movies.
MEDIA_FOLDER=C:\path\to\your\tv-shows

# Required: OpenAI-compatible API key.
OPENAI_API_KEY=sk-your-api-key-here

# Optional: API endpoint and model.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120
OPENAI_BATCH_SIZE=25

# Optional dry-run controls.
# 0 = real rename/write, 1 = dry-run mode
DRY_RUN=1

# Optional: when DRY_RUN=1, write renamed copies and NFO files here.
# Leave blank to do log-only dry-run without writing files.
DRY_RUN_FOLDER=D:\ShowRenaming\_dryrun

# Note: API requests and responses are automatically logged to
# MEDIA_FOLDER/logs/ai_rename_YYYYMMDD_HHMMSS.log (one file per run).
